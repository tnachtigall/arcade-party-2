{
  "schemaVersion": 1,
  "id": "ap2-host-default",
  "version": "${version}",
  "name": "Arcade Party 2",
  "description": "An arcade minigame for modern Minecraft where the players must win as many challenges as possible in order to win the game!",
  "authors": [
    "LCLP",
    "bops"
  ],
  "contact": {
    "homepage": "https://github.com/LCLPYT/arcade-party-2",
    "sources": "https://github.com/LCLPYT/arcade-party-2"
  },
  "license": "MIT",
  "environment": "server",
  "entrypoints": {
    "game-entry": [
      "work.lclpnet.ap2.host_default.ArcadePartyDefaultGame"
    ]
  },
  "depends": {
    "fabricloader": ">=0.16.14",
    "minecraft": "~1.21.6",
    "java": ">=21",
    "ap2-lib": "*",
    "mg-lobby": "*",
    "kibu": "*",
    "notica": "*",
    "combat-control": "*",
    "fantasy": "*",
    "kibu-world-api": "*",
    "sqlite-jdbc": "*"
  },
  "suggests": {
    "pal": "*",
    "mcserver-api": "*"
  },
  "custom": {
    "modmenu": {
      "parent": "ap2"
    }
  }
}